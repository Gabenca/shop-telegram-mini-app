{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "paths": [".opencode/skills"]
  },
  "lsp": true,
  "plugin": [
    "orient@learning-opportunities",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "mcp": {
    "serena": {
      "type": "local",
      "command": ["C:\\Users\\max99\\.local\\bin\\serena.exe", "start-mcp-server", "--context", "opencode", "--project-from-cwd"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["cmd", "/c", "npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": ["cmd", "/c", "npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true
    }
  }
}
